---
interface Props { 
  as?: "meta" | "img";
  alt: string;
  src?: string;
  debug?: boolean;
  width?: number;
  height?: number;
  [key: string]: any;
}
const {
  as: tag = "meta",
  src = "",
  alt,
  debug,
  width = 1200,
  height = 630,
  ...props
} = Astro.props;

let component = src.replace(/(^\/)|(\/$)/g, "");
const url = new URL(
  `/_og${component ? `/${component}` : ""}`,
  Astro.url.origin
);
for (const [key, value] of Object.entries({ debug, width, height })) {
  if (value) {
    if (key === "width" && value === 1200) continue;
    if (key === "height" && value === 630) continue;
    url.searchParams.set(key, value.toString());
  }
}
for (const [key, value] of Object.entries(props)) {
  url.searchParams.set(key, value.toString());
}
---

{
  tag === "meta" ? (
    <meta property="og:image" content={url.toString()} />
    <meta property="og:image:width" content={width.toString()} />
    <meta property="og:image:height" content={height.toString()} />
    <meta property="og:image:alt" content={alt} />
  ) : (
    <img
      style={`width:100%;height:auto;`}
      src={url.toString()}
      {...{ width, height }}
    />
  )
}
