---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Find prev/next
const allPosts = await getCollection('posts');
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIdx = sorted.findIndex(p => p.id === post.id);
const prev = currentIdx < sorted.length - 1 ? sorted[currentIdx + 1] : null;
const next = currentIdx > 0 ? sorted[currentIdx - 1] : null;

// Related posts (by tags)
const related = sorted
  .filter(p => p.id !== post.id && p.data.tags?.some(t => post.data.tags?.includes(t)))
  .slice(0, 3);
const fmt = (d) => d.toISOString().slice(0, 10);

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  description: post.data.description || '',
  author: {
    '@type': 'Person',
    name: 'Lcc',
  },
  keywords: (post.data.tags || []).join(', '),
};

// Post age check
const now = new Date();
const postAge = Math.floor((now.getTime() - post.data.date.getTime()) / (365.25 * 24 * 60 * 60 * 1000));
---

<PageLayout title={post.data.title} description={post.data.description} math={post.data.math}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <article class="post-card">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={fmt(post.data.date)}>{fmt(post.data.date)}</time>
        <span class="meta-separator">·</span>
        <span>{post.body.length} 字 · 约 {Math.ceil(post.body.length / 200)} 分钟</span>
        {post.data.categories?.length > 0 && (
          <>
            <span class="meta-separator">·</span>
            <span class="post-categories">{post.data.categories.join(' / ')}</span>
          </>
        )}
        <span class="meta-separator">·</span>
        <button class="copy-link-btn" id="copy-link-btn" title="复制链接" aria-label="复制文章链接">复制链接</button>
      </div>
    </header>

    {postAge >= 1 && (
      <div class="post-age-notice">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="12" x2="12" y2="8"/><line x1="12" y1="16" x2="12.01" y2="16"/><line x1="12" y1="12" x2="16" y2="12"/></svg>
        <span>本文写于 {postAge} 年前，内容可能已过时</span>
      </div>
    )}

    <div class="post-content">
      <Content />
    </div>

    {post.data.tags?.length > 0 && (
      <div class="post-footer-tags">
        {post.data.tags.map(tag => (
          <a href={`/tags/#${tag}`} class="post-tag">{tag}</a>
        ))}
      </div>
    )}

    <nav class="post-nav">
      <div class="post-nav-prev">
        {prev && (
          <a href={`/posts/${prev.id}/`} rel="prev">
            <span class="nav-label">← 上一篇</span>
            <span class="nav-title">{prev.data.title}</span>
          </a>
        )}
      </div>
      <div class="post-nav-next">
        {next && (
          <a href={`/posts/${next.id}/`} rel="next">
            <span class="nav-label">下一篇 →</span>
            <span class="nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>

    {post.data.comments !== false && (
      <div class="comments-section">
        <script is:inline src="https://giscus.app/client.js"
          data-repo="lccccc1024/lccccc1024.github.io"
          data-repo-id="R_kgDOIBXa0g"
          data-category="Announcements"
          data-category-id="DIC_kwDOIBXa0s4C6Wys"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="preferred_color_scheme"
          data-lang="zh-CN"
          data-loading="lazy"
          crossorigin="anonymous"
          async>
        </script>
      </div>
    )}

    {related.length > 0 && (
      <div class="related-posts">
        <h3 class="related-title">相关文章</h3>
        <ul class="related-list">
          {related.map(rp => (
            <li>
              <a href={`/posts/${rp.id}/`}>
                <span class="related-post-title">{rp.data.title}</span>
                <span class="related-post-date">{fmt(rp.data.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </article>

  <script src="/js/toc.js" defer data-astro-rerun></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('copy-link-btn');
      if (!btn) return;
      btn.addEventListener('click', function() {
        navigator.clipboard.writeText(window.location.href).then(function() {
          btn.textContent = '已复制';
          btn.classList.add('copied');
          setTimeout(function() {
            btn.textContent = '复制链接';
            btn.classList.remove('copied');
          }, 2000);
        }).catch(function() {
          btn.textContent = '复制失败';
          setTimeout(function() { btn.textContent = '复制链接'; }, 2000);
        });
      });
    });
  </script>
</PageLayout>
