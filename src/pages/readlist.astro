---
import PageLayout from '../layouts/PageLayout.astro';
import books from '../data/books';
---

<PageLayout title="阅读清单" description="个人阅读清单">
  <div class="list-page-header">
    <h1 class="list-page-title">阅读清单</h1>
    <p class="list-page-subtitle">书页翻过去的时候，也把一段时间留了下来。</p>
  </div>

  <div class="list-page-content">
    <p class="stats">共记录 <strong>{books.length}</strong> 本书（按添加顺序排列）</p>

    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>书名</th>
            <th>作者</th>
            <th>类型</th>
            <th>出版年份</th>
            <th>阅读时间</th>
          </tr>
        </thead>
        <tbody>
          {books.map((book, i) => (
            <tr>
              <td data-label="序号">{i + 1}</td>
              <td data-label="书名">
                {book.url
                  ? <a href={book.url} target="_blank" rel="noopener">{book.title}</a>
                  : book.title}
              </td>
              <td data-label="作者">{book.author}</td>
              <td data-label="类型"><span class="genre-badge">{book.genre}</span></td>
              <td data-label="出版年份">{book.year || '-'}</td>
              <td data-label="阅读时间">
                {book.date === '搁浅'
                  ? <span class="status-abandoned">搁浅</span>
                  : (book.date || '')}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</PageLayout>
