---
import PageLayout from '../layouts/PageLayout.astro';
import movies from '../data/movies';

const reverseMovies = [...movies].reverse();
---

<PageLayout title="电影清单" description="个人电影观看记录清单">
  <div class="list-page-header">
    <h1 class="list-page-title">电影清单</h1>
    <p class="list-page-subtitle">至少还有电影，幸好还有电影。</p>
  </div>

  <div class="list-page-content">
    <p class="stats">共记录 <strong>{movies.length}</strong> 部电影（按添加顺序）</p>

    <div class="table-container">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>片名</th>
            <th>类型</th>
            <th>导演</th>
            <th>上映年份</th>
            <th>观看时间</th>
          </tr>
        </thead>
        <tbody>
          {reverseMovies.map((movie, i) => (
            <tr>
              <td data-label="序号">{i + 1}</td>
              <td data-label="片名">{movie.title}</td>
              <td data-label="类型"><span class="genre-badge">{movie.genre}</span></td>
              <td data-label="导演">{movie.director}</td>
              <td data-label="上映年份">{movie.year}</td>
              <td data-label="观看时间">{movie.date || '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</PageLayout>
