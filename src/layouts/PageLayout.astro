---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  description?: string;
  math?: boolean;
}

const { title, description, math } = Astro.props;
---

<BaseLayout title={title} description={description} math={math}>
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">闲话</a>
      <ul class="nav-links">
        <li><a href="/">首页</a></li>
        <li><a href="/archive/">归档</a></li>
        <li class="nav-dropdown">
          <a class="nav-dropdown-trigger">清单</a>
          <ul class="nav-dropdown-menu">
            <li><a href="/light/">电影清单</a></li>
            <li><a href="/readlist/">阅读清单</a></li>
            <li><a href="/want/">心愿单</a></li>
          </ul>
        </li>
        <li><a href="/tags/">标签</a></li>
        <li><a href="/categories/">分类</a></li>
        <li><a href="/about/">关于</a></li>
        <li><a href="/feed.xml" id="nav-rss">RSS</a></li>
      </ul>
      <button id="theme-toggle-nav" class="theme-toggle-nav" aria-label="切换深色/浅色主题">
        <span class="theme-icon-nav"></span>
      </button>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="菜单">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <div class="nav-overlay" id="nav-overlay">
    <ul class="nav-overlay-links">
      <li><a href="/">首页</a></li>
      <li class="overlay-section">清单</li>
      <li class="overlay-sub"><a href="/light/">电影清单</a></li>
      <li class="overlay-sub"><a href="/readlist/">阅读清单</a></li>
      <li class="overlay-sub"><a href="/want/">心愿单</a></li>
      <li><a href="/tags/">标签</a></li>
      <li><a href="/categories/">分类</a></li>
      <li><a href="/about/">关于</a></li>
      <li><a href="/feed.xml">RSS</a></li>
    </ul>
  </div>

  <main class="page-content" id="main-content" aria-label="内容" transition:animate="slide">
    <div class="wrapper">
      <slot />
    </div>
  </main>

  <button class="back-to-top" id="back-to-top" title="返回顶部" aria-label="返回顶部">
    <svg class="back-to-top-ring" width="44" height="44" viewBox="0 0 44 44" aria-hidden="true">
      <circle class="ring-bg" cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="2" opacity="0.15"/>
      <circle class="ring-fill" id="ring-fill" cx="22" cy="22" r="19" fill="none" stroke="currentColor" stroke-width="2.5" stroke-dasharray="119.38" stroke-dashoffset="119.38" stroke-linecap="round" transform="rotate(-90 22 22)"/>
    </svg>
    <svg class="back-to-top-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="18 15 12 9 6 15"></polyline>
    </svg>
  </button>

  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-copy">&copy; 2026 Lcc</span>
      <span class="footer-sep">·</span>
      <span class="footer-powered">Powered by Astro</span>
    </div>
  </footer>

  <script data-astro-rerun>
    // Hamburger menu
    document.addEventListener('DOMContentLoaded', function() {
      var hamburger = document.getElementById('nav-hamburger');
      var overlay = document.getElementById('nav-overlay');
      if (hamburger && overlay) {
        hamburger.addEventListener('click', function() {
          overlay.classList.toggle('active');
          hamburger.classList.toggle('active');
        });
        overlay.querySelectorAll('a').forEach(function(l) {
          l.addEventListener('click', function() {
            overlay.classList.remove('active');
            hamburger.classList.remove('active');
          });
        });
      }
    });
  </script>
  <script data-astro-rerun>
    // Back to top
    document.addEventListener('DOMContentLoaded', function() {
      var btn = document.getElementById('back-to-top');
      var ring = document.getElementById('ring-fill');
      if (!btn) return;
      var circumference = 119.38;
      window.addEventListener('scroll', function() {
        var scrollTop = window.scrollY;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        var progress = docHeight > 0 ? scrollTop / docHeight : 0;
        btn.classList.toggle('visible', scrollTop > 300);
        if (ring) ring.style.strokeDashoffset = circumference * (1 - progress);
      }, { passive: true });
      btn.addEventListener('click', function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  </script>
</BaseLayout>
